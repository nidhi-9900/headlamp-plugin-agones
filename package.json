{
  "name": "headlamp-plugin-agones",
  "version": "0.0.1-poc",
  "description": "Headlamp plugin that surfaces Agones GameServer, Fleet, and GameServerSet CRDs with list/detail views and relational navigation.",
  "private": true,
  "scripts": {
    "start": "headlamp-plugin start",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "tsc": "headlamp-plugin tsc",
    "test": "headlamp-plugin test"
  },
  "keywords": [
    "headlamp",
    "headlamp-plugin",
    "kubernetes",
    "agones",
    "gameserver",
    "fleet"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.13.1"
  },
  "overrides": {
    "typescript": "5.6.2"
  }
